<style>
:root {
  --bg: #FAFAFA;
  --surface: #FFFFFF;
  --surface2: #F4F4F4;
  --border: #E8E8E8;
  --border2: #D4D4D4;
  --text: #111111;
  --text2: #555555;
  --text3: #999999;
  --accent: #E84C1E;
  --accent2: #FF6B3D;
  --accent-bg: #FFF2EE;
  --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
  --shadow: 0 4px 16px rgba(0,0,0,.08);
  --shadow-lg: 0 12px 40px rgba(0,0,0,.12);
  --radius: 12px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Plus Jakarta Sans',sans-serif;line-height:1.6;overflow-x:hidden;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(250,250,250,.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);height:58px;display:flex;align-items:center;padding:0 6%;gap:32px;}
.nav-logo{font-weight:800;font-size:.92rem;color:var(--text);letter-spacing:-.3px;white-space:nowrap;}
.nav-logo span{color:var(--accent);}
.nav-links{display:flex;gap:24px;margin-left:auto;}
.nav-links a{color:var(--text2);text-decoration:none;font-size:.8rem;font-weight:500;transition:color .15s;}
.nav-links a:hover{color:var(--accent);}
.nav-badge{background:var(--accent);color:#fff;font-size:.68rem;font-weight:700;padding:4px 11px;border-radius:100px;white-space:nowrap;}

/* HERO */
#hero{min-height:100vh;padding:100px 6% 70px;display:grid;grid-template-columns:1fr 400px;gap:60px;align-items:center;background:var(--surface);border-bottom:1px solid var(--border);}
.hero-tag{display:inline-flex;align-items:center;gap:7px;background:var(--accent-bg);border:1px solid #F5C9BC;color:var(--accent);font-size:.72rem;font-weight:700;letter-spacing:.5px;padding:5px 12px;border-radius:100px;margin-bottom:22px;text-transform:uppercase;}
.hero-tag::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;}
h1.hero-name{font-size:clamp(2.8rem,5.5vw,4.4rem);font-weight:800;line-height:1.05;letter-spacing:-.5px;margin-bottom:16px;}
h1.hero-name em{font-family:'Instrument Serif',serif;font-style:italic;color:var(--accent);font-weight:400;}
.hero-sub{font-size:.97rem;color:var(--text2);max-width:500px;line-height:1.75;margin-bottom:26px;}
.hero-pills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:30px;}
.pill{background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-size:.73rem;font-weight:600;padding:5px 12px;border-radius:100px;}
.hero-actions{display:flex;gap:10px;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:10px 22px;border-radius:8px;font-size:.84rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all .15s;border:none;font-family:inherit;}
.btn-primary{background:var(--text);color:#fff;}
.btn-primary:hover{background:#333;transform:translateY(-1px);box-shadow:var(--shadow);}
.btn-secondary{background:var(--surface);color:var(--text);border:1px solid var(--border2);}
.btn-secondary:hover{border-color:var(--text2);}

/* Hero photo */
.hero-photo-wrap{display:flex;justify-content:center;align-items:flex-end;position:relative;}
.hero-photo-bg{width:340px;height:430px;border-radius:20px;overflow:hidden;border:1px solid var(--border);position:relative;box-shadow:var(--shadow);}
.hero-photo-bg img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;}
.hero-stat-card{position:absolute;background:var(--surface);border:1px solid var(--border);box-shadow:var(--shadow);padding:11px 16px;border-radius:10px;}
.hero-stat-card.s1{bottom:24px;left:-28px;}
.hero-stat-card.s2{top:36px;right:-22px;}
.stat-num{font-size:1.4rem;font-weight:800;color:var(--text);letter-spacing:-.5px;}
.stat-lbl{font-size:.62rem;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px;}
.stat-dot{width:7px;height:7px;border-radius:50%;background:#22C55E;display:inline-block;margin-right:3px;}

/* SECTIONS */
section{padding:72px 6%;}
.sec-eyebrow{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--accent);margin-bottom:6px;}
.sec-heading{font-size:clamp(1.8rem,3.2vw,2.5rem);font-weight:800;letter-spacing:-.4px;line-height:1.15;margin-bottom:6px;}
.divider{width:36px;height:3px;background:var(--accent);border-radius:3px;margin:10px 0 44px;}

/* ABOUT */
#about{background:var(--bg);}
.about-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:56px;align-items:start;}
.about-text p{color:var(--text2);font-size:.93rem;line-height:1.8;margin-bottom:14px;}
.about-text strong{color:var(--text);font-weight:700;}
.contact-list{margin-top:24px;display:flex;flex-direction:column;gap:9px;}
.contact-item{display:flex;align-items:center;gap:11px;font-size:.86rem;color:var(--text2);}
.contact-icon{width:32px;height:32px;background:var(--accent-bg);border:1px solid #F5C9BC;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;}
.contact-item a{color:var(--text2);text-decoration:none;font-weight:500;}
.contact-item a:hover{color:var(--accent);}
.skills-block{display:flex;flex-direction:column;gap:14px;}
.skill-group{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;}
.skill-group-title{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text3);margin-bottom:10px;}
.tags{display:flex;flex-wrap:wrap;gap:5px;}
.tag{background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-size:.72rem;font-weight:600;padding:3px 9px;border-radius:5px;}
.tag.accent{background:var(--accent-bg);border-color:#F5C9BC;color:var(--accent);}

/* EDUCATION */
#education{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.edu-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:28px 32px;max-width:740px;position:relative;overflow:hidden;}
.edu-card::before{content:'';position:absolute;top:0;left:0;bottom:0;width:4px;background:var(--accent);border-radius:4px 0 0 4px;}
.edu-school{font-size:1.25rem;font-weight:800;letter-spacing:-.3px;}
.edu-degree{font-size:.86rem;font-weight:600;color:var(--accent);margin:4px 0 14px;}
.edu-meta{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px;}
.edu-chip{background:var(--surface);border:1px solid var(--border);font-size:.76rem;font-weight:600;color:var(--text2);padding:4px 11px;border-radius:6px;}
.edu-chip.hi{background:var(--accent-bg);border-color:#F5C9BC;color:var(--accent);}
.edu-ach{display:flex;flex-direction:column;gap:7px;}
.edu-ach-item{display:flex;align-items:flex-start;gap:9px;font-size:.84rem;color:var(--text2);line-height:1.55;}
.edu-ach-item::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:6px;}

/* EXPERIENCE */
#experience{background:var(--bg);}
.timeline{display:flex;flex-direction:column;}
.tl-item{display:grid;grid-template-columns:210px 1fr;position:relative;}
.tl-item+.tl-item{border-top:1px solid var(--border);}
.tl-left{padding:32px 28px 32px 0;}
.tl-period{font-size:.72rem;font-weight:700;color:var(--accent);letter-spacing:.3px;margin-bottom:4px;}
.tl-company{font-size:.86rem;font-weight:700;color:var(--text);margin-bottom:2px;}
.tl-dept{font-size:.76rem;color:var(--text3);}
.tl-sep{position:absolute;top:0;bottom:0;left:210px;width:1px;background:var(--border);}
.tl-sep-dot{position:absolute;left:-5px;top:40px;width:11px;height:11px;border-radius:50%;background:var(--bg);border:2px solid var(--accent);}
.tl-right{padding:32px 0 32px 36px;}
.tl-role{font-size:1.1rem;font-weight:800;letter-spacing:-.2px;margin-bottom:7px;}
.tl-desc{font-size:.86rem;color:var(--text2);line-height:1.7;margin-bottom:12px;max-width:580px;}
.tl-points{display:flex;flex-direction:column;gap:6px;}
.tl-point{display:flex;align-items:flex-start;gap:9px;font-size:.83rem;color:var(--text2);line-height:1.55;}
.tl-point::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:7px;}
.tl-tools{display:flex;flex-wrap:wrap;gap:5px;margin-top:14px;}
.tl-tool{background:var(--surface);border:1px solid var(--border);color:var(--text2);font-size:.7rem;font-weight:600;padding:3px 9px;border-radius:5px;}

/* PROJECTS */
#projects{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.proj-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;cursor:pointer;transition:transform .18s,box-shadow .18s,border-color .18s;display:flex;flex-direction:column;}
.proj-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--border2);}
.proj-thumb{height:170px;overflow:hidden;position:relative;flex-shrink:0;background:var(--surface2);}
.proj-thumb img{width:100%;height:100%;object-fit:cover;object-position:top;transition:transform .3s;}
.proj-card:hover .proj-thumb img{transform:scale(1.03);}
.proj-badge{position:absolute;top:10px;left:10px;background:rgba(255,255,255,.92);border:1px solid var(--border);font-size:.62rem;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--text2);padding:3px 8px;border-radius:5px;backdrop-filter:blur(4px);}
.proj-body{padding:16px 18px;flex:1;display:flex;flex-direction:column;}
.proj-title{font-size:.93rem;font-weight:800;letter-spacing:-.2px;line-height:1.3;margin-bottom:6px;}
.proj-desc{font-size:.78rem;color:var(--text2);line-height:1.65;flex:1;}
.proj-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:10px;}
.proj-tag{background:var(--surface);border:1px solid var(--border);color:var(--text3);font-size:.65rem;font-weight:600;padding:2px 7px;border-radius:4px;}
.proj-footer{padding:9px 18px 12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:5px;font-size:.7rem;color:var(--text3);font-weight:600;}

/* MODAL */
.modal-backdrop{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.5);backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:20px;}
.modal-backdrop.open{display:flex;}
.modal{background:var(--surface);border-radius:16px;border:1px solid var(--border);max-width:800px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-lg);position:relative;animation:modalIn .2s ease;}
@keyframes modalIn{from{opacity:0;transform:scale(.96) translateY(12px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-close-btn{position:sticky;top:0;float:right;margin:14px 14px 0 0;width:30px;height:30px;border-radius:50%;background:var(--surface2);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85rem;color:var(--text2);z-index:10;transition:background .15s;}
.modal-close-btn:hover{background:var(--border);}
.modal-header{padding:28px 32px 20px;border-bottom:1px solid var(--border);clear:both;}
.modal-eyebrow{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--accent);margin-bottom:7px;}
.modal-title{font-size:1.45rem;font-weight:800;letter-spacing:-.3px;line-height:1.2;}
.modal-content{padding:24px 32px 32px;}
.modal-content p{font-size:.88rem;color:var(--text2);line-height:1.8;margin-bottom:12px;}
.modal-content h4{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text3);margin:20px 0 10px;}
.modal-imgs{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:8px 0 16px;}
.modal-imgs.single{grid-template-columns:1fr;}
.modal-imgs.three{grid-template-columns:1fr 1fr 1fr;}
.modal-imgs.four{grid-template-columns:1fr 1fr;}
.modal-img{border-radius:8px;overflow:hidden;border:1px solid var(--border);}
.modal-img img{width:100%;height:auto;display:block;}
.modal-img .caption{font-size:.68rem;color:var(--text3);padding:6px 10px;background:var(--surface2);font-weight:600;}
.modal-list{display:flex;flex-direction:column;gap:7px;}
.modal-list-item{display:flex;align-items:flex-start;gap:9px;font-size:.86rem;color:var(--text2);line-height:1.6;}
.modal-list-item::before{content:'→';color:var(--accent);flex-shrink:0;font-weight:700;margin-top:1px;}
.modal-table{width:100%;border-collapse:collapse;font-size:.8rem;margin:8px 0;border-radius:8px;overflow:hidden;border:1px solid var(--border);}
.modal-table th{background:var(--surface2);color:var(--text);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border);}
.modal-table td{padding:8px 12px;border-bottom:1px solid var(--border);color:var(--text2);}
.modal-table tr:last-child td{border-bottom:none;font-weight:700;color:var(--text);}
.modal-table tr:hover td{background:var(--surface2);}

/* ORG */
#organization{background:var(--bg);}
.org-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;}
.org-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px 22px;transition:border-color .15s,box-shadow .15s;}
.org-card:hover{border-color:var(--border2);box-shadow:var(--shadow-sm);}
.org-year-badge{display:inline-block;background:var(--accent-bg);border:1px solid #F5C9BC;color:var(--accent);font-size:.65rem;font-weight:700;padding:3px 9px;border-radius:100px;margin-bottom:9px;}
.org-role{font-size:.94rem;font-weight:800;letter-spacing:-.2px;margin-bottom:2px;}
.org-name{font-size:.76rem;color:var(--text3);margin-bottom:12px;font-weight:500;}
.org-points{display:flex;flex-direction:column;gap:5px;}
.org-point{display:flex;align-items:flex-start;gap:7px;font-size:.79rem;color:var(--text2);line-height:1.55;}
.org-point::before{content:'–';color:var(--accent);flex-shrink:0;font-weight:700;}

/* CONTACT */
#contact{background:var(--text);color:#fff;text-align:center;padding:80px 6%;}
.contact-big{font-size:clamp(2.8rem,7vw,5.5rem);font-weight:800;letter-spacing:-.5px;line-height:1;margin:16px 0 32px;}
.contact-big em{font-family:'Instrument Serif',serif;font-style:italic;color:var(--accent2);font-weight:400;}
.contact-cards{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:36px;}
.contact-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius);padding:16px 22px;display:flex;align-items:center;gap:12px;text-align:left;}
.contact-card-icon{width:38px;height:38px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;}
.contact-card-text strong{display:block;font-size:.86rem;font-weight:700;color:#fff;margin-bottom:1px;}
.contact-card-text span{font-size:.73rem;color:rgba(255,255,255,.45);}
.contact-btns{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;}
.btn-white{background:#fff;color:var(--text);}
.btn-white:hover{background:#eee;}
.btn-ghost{background:transparent;border:1px solid rgba(255,255,255,.25);color:#fff;}
.btn-ghost:hover{border-color:rgba(255,255,255,.5);}
footer{background:var(--text);border-top:1px solid rgba(255,255,255,.08);padding:16px 6%;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;}
footer span{font-size:.7rem;color:rgba(255,255,255,.3);}

@media(max-width:900px){
  #hero{grid-template-columns:1fr;}
  .hero-photo-wrap{display:none;}
  .about-grid{grid-template-columns:1fr;gap:32px;}
  .tl-item{grid-template-columns:1fr;}
  .tl-sep{display:none;}
  .tl-left{padding-bottom:0;}
  .tl-right{padding-left:0;}
  .proj-grid{grid-template-columns:repeat(2,1fr);}
  .modal-imgs{grid-template-columns:1fr;}
  .modal-imgs.three{grid-template-columns:1fr 1fr;}
  .modal-header,.modal-content{padding:20px;}
}
@media(max-width:560px){
  .proj-grid{grid-template-columns:1fr;}
}
</style>
</head>
